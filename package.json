{
  "name": "nura-store",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "next lint",
    "prisma:generate": "prisma generate && prisma generate --schema prisma/sqlite.prisma",
    "prisma:push": "prisma db push",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "sqlite:migrate:identity": "sqlite3 prisma/dev.db < prisma/sqlite-identity-migration.sql",
    "seed": "node prisma/seed.mjs",
    "preview:migrate-data": "node scripts/migrate-preview-data.mjs",
    "images:generate-four": "node scripts/generate-product-four-image-set.mjs",
    "images:publish-four": "node scripts/publish-product-four-image-set.mjs",
    "sync:images": "node scripts/sync-product-images.mjs",
    "social:draft": "node scripts/generate-social-draft.mjs",
    "social:draft:dry-run": "node scripts/generate-social-draft.mjs --dry-run"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "@vercel/blob": "^1.1.1",
    "next": "^16.2.9",
    "prisma": "6.19.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.2.9",
    "typescript": "^5.7.0"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  }
}
