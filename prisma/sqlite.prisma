generator client {
  provider = "prisma-client-js"
  output   = "../generated/sqlite-client"
}

datasource db {
  provider = "sqlite"
  url      = env("SQLITE_DATABASE_URL")
}

model Product {
  id                 String          @id @default(cuid())
  sku                String          @unique
  sourceCode         String?
  legacyCode         String?         @unique
  category           ProductCategory
  color              ProductColor    @default(UNKNOWN)
  gemstoneType       GemstoneType    @default(UNKNOWN)
  name               String
  description        String
  titleEn            String?
  titleAr            String?
  shortDescriptionEn String?
  shortDescriptionAr String?
  detailEn           String?
  detailAr           String?
  material           String?
  priceAed           Float?
  stock              Int             @default(0)
  tags               String?
  collectionName     String?
  certificateAuthority String?
  certificateNumber String?
  certificateUrl    String?
  purchasePrice      Float
  shippingFee        Float
  packagingFee       Float
  cost               Float
  rawSuggestedPrice  Float
  price              Int
  priceReviewStatus  String
  status             ProductStatus   @default(DRAFT)
  images             ProductImage[]
  orderItems         OrderItem[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model ProductImage {
  id        String    @id @default(cuid())
  productId String
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      ImageType
  path      String
  alt       String?
  approved  Boolean   @default(false)
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
}

model Order {
  id                String            @id @default(cuid())
  orderNumber       String            @unique
  customerName      String?
  email             String?
  phone             String?
  fulfillmentStatus FulfillmentStatus @default(PENDING_CONFIRMATION)
  paymentMethod     String?
  shippingCarrier   String?
  trackingNumber    String?
  internalNote      String?
  shippingName      String?
  shippingPhone     String?
  shippingEmail     String?
  shippingAddress   String?
  currency          String            @default("AED")
  total             Int
  status            OrderStatus       @default(PENDING)
  items             OrderItem[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  sku       String
  name      String
  price     Int
  quantity  Int
}

enum ProductCategory {
  NECKLACE
  EARRING
  BRACELET
  RING
  SET
}

enum ProductColor {
  YELLOW
  RED
  PINK
  BLUE
  GREEN
  COLORLESS
  UNKNOWN
}

enum GemstoneType {
  LAB_GROWN_DIAMOND
  MOISSANITE
  LAB_GROWN_COLORED_GEMSTONE
  OTHER
  UNKNOWN
}

enum ProductStatus {
  DRAFT
  REVIEW
  ACTIVE
  ARCHIVED
}

enum ImageType {
  RAW
  ECOMMERCE_WHITE
  WARMWHITE
  SCENE
  MODEL_WEAR
  BANNER
  SOCIAL
  DETAIL
}

enum OrderStatus {
  PENDING
  PAID_SIMULATED
  CANCELLED
}

enum FulfillmentStatus {
  PENDING_PAYMENT
  PENDING_CONFIRMATION
  PENDING_SHIPMENT
  SHIPPED
  COMPLETED
  AFTER_SALES
  CANCELLED
}
